/**
 * emailService.ts
 *
 * Envia emails via EmailJS (usa o teu servidor SMTP por baixo, sem backend).
 *
 * CONFIGURAÇÃO — 3 passos:
 *  1. Cria conta gratuita em https://www.emailjs.com
 *  2. Em "Email Services" → Add Service → escolhe SMTP e preenche:
 *       Host, Port, User, Password do teu servidor SMTP
 *  3. Em "Email Templates" → Create Template com as variáveis:
 *       {{from_name}}, {{from_email}}, {{message}}, {{to_name}}
 *  4. Substitui as 3 constantes abaixo com os teus IDs reais.
 */

// ─── Substitui com os teus valores do dashboard EmailJS ───────────────────────
const EMAILJS_SERVICE_ID  = "mail.angohost.email";   // Email Services → Service ID
const EMAILJS_TEMPLATE_ID = "lurdes.joao@vlk-techflow.ao";  // Email Templates → Template ID
const EMAILJS_PUBLIC_KEY  = "lurdes@123#"; // Account → Public Key
// ──────────────────────────────────────────────────────────────────────────────

export interface EmailPayload {
  nome:      string;
  email:     string;
  mensagem:  string;
}

export type SendStatus = "idle" | "sending" | "success" | "error";

/**
 * Carrega o SDK do EmailJS dinamicamente (evita bundle desnecessário se o
 * utilizador nunca abrir o formulário).
 */
async function loadEmailJS(): Promise<typeof import("@emailjs/browser")> {
  return import("@emailjs/browser");
}

/**
 * Envia o email com os dados do formulário.
 * Lança um Error se o envio falhar — trata no chamador.
 */
export async function sendContactEmail(payload: EmailPayload): Promise<void> {
  const emailjs = await loadEmailJS();

  const templateParams = {
    from_name:  payload.nome,
    from_email: payload.email,
    message:    payload.mensagem,
    to_name:    "VLK-Techflow",             // nome que aparece no email recebido
    reply_to:   payload.email,
  };

  const response = await emailjs.send(
    EMAILJS_SERVICE_ID,
    EMAILJS_TEMPLATE_ID,
    templateParams,
    { publicKey: EMAILJS_PUBLIC_KEY }
  );

  if (response.status !== 200) {
    throw new Error(`EmailJS retornou status ${response.status}: ${response.text}`);
  }
}

